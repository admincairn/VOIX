    "lucide-react": "^0.383.0",
    "next": "14.2.5",
    "next-auth": "^5.0.0-beta.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^3.4.0",
    "tailwind-merge": "^2.4.0",
    "zod": "^3.23.8"
