# ============================================================
# VOIX — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# ── App ──────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                          # openssl rand -base64 32
NEXT_PUBLIC_APP_URL=http://localhost:3000  # Used for widget embed snippets

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=                 # https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=            # eyJhb...
SUPABASE_SERVICE_ROLE_KEY=                # eyJhb... (server-only, never expose)

# ── Auth Providers ────────────────────────────────────────────
GOOGLE_CLIENT_ID=                         # From Google Cloud Console
GOOGLE_CLIENT_SECRET=

# ── Lemon Squeezy (US Merchant of Record) ────────────────────
LEMON_SQUEEZY_API_KEY=                    # ls_live_...
LEMON_SQUEEZY_STORE_ID=                   # Numeric ID from LS dashboard
LEMON_SQUEEZY_WEBHOOK_SECRET=             # Set in LS dashboard

# Variant IDs (monthly plans — from your LS product variants)
LS_VARIANT_STARTER=
LS_VARIANT_GROWTH=
LS_VARIANT_SCALE=

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=                           # re_...
RESEND_FROM_DOMAIN=voix.app               # Must be verified in Resend

# ── Optional: Sentry error tracking ──────────────────────────
# SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ── Google Places API (Import module) ────────────────────────
GOOGLE_PLACES_API_KEY=                    # From Google Cloud Console → APIs & Services → Credentials
                                          # Enable: Places API + Maps JavaScript API
                                          # Restrict key to: Maps Embed API, Places API (server)
